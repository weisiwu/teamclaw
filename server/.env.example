# ============================================================
# TeamClaw Server 环境变量示例
# 复制此文件为 .env 并填写真实值
# ============================================================

# ── 服务器基础配置 ──────────────────────────────────────────
# 服务监听端口（默认 9700）
PORT=9700

# Node.js 运行环境（development / production / test）
NODE_ENV=development

# ── PostgreSQL 数据库配置 ───────────────────────────────────
# 完整连接字符串（优先使用，格式：postgresql://user:password@host:port/dbname）
DATABASE_URL=postgresql://teamclaw:password@localhost:5432/teamclaw

# 以下为分解配置，DATABASE_URL 未填写时使用
DB_HOST=localhost
DB_PORT=5432
DB_NAME=teamclaw
DB_USER=teamclaw
DB_PASSWORD=password

# ── Redis 缓存配置 ──────────────────────────────────────────
# Redis 连接地址
REDIS_URL=redis://localhost:6379

# ── JWT 认证配置 ───────────────────────────────────────────
# JWT 签名密钥（请在生产环境使用强随机字符串，至少 32 字符）
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT token 有效期（单位：秒，默认 7 天）
JWT_EXPIRES_IN=604800

# ── 飞书集成配置 ───────────────────────────────────────────
# 飞书应用 App ID（从飞书开放平台获取）
FEISHU_APP_ID=

# 飞书应用 App Secret
FEISHU_APP_SECRET=

# ── LLM API Keys（按需配置）─────────────────────────────────
# DeepSeek API Key
DEEPSEEK_API_KEY=

# OpenAI API Key
OPENAI_API_KEY=

# Anthropic API Key
ANTHROPIC_API_KEY=

# ── 服务地址配置 ───────────────────────────────────────────
# 当前服务对外 URL（用于 CORS 和 Webhook回调，生产环境需填写真实地址）
SERVER_URL=http://localhost:9700

# ── Chroma 向量数据库配置 ──────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
