# LLM API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Optional: custom model overrides
# LIGHT_MODEL=gpt-4o-mini
# MEDIUM_MODEL=gpt-4o
# STRONG_MODEL=claude-sonnet-4-20250514
# OPENAI_BASE_URL=https://api.openai.com/v1

# Server
PORT=9700
JWT_SECRET=dev-secret-change-in-production

# Database (must match docker-compose.yml: user=teamclaw, password=password)
