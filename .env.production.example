# ============================================================
# TeamClaw Production Environment Variables
# Copy this file to .env.production and fill in the values
# NEVER commit .env.production to version control!
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=production
PORT=3000
SERVER_PORT=9700
SERVER_URL=https://teamclaw.yourdomain.com

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://teamclaw:YOUR_SECURE_PASSWORD@postgres:5432/teamclaw
DB_HOST=postgres
DB_PORT=5432
DB_NAME=teamclaw
DB_USER=teamclaw
DB_PASSWORD=YOUR_SECURE_PASSWORD

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ── ChromaDB (Vector Store) ─────────────────────────────────
CHROMA_HOST=chroma
CHROMA_PORT=8000

# ── LLM API Keys ────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Authentication ──────────────────────────────────────────
JWT_SECRET=YOUR_VERY_LONG_RANDOM_SECRET_HERE_AT_LEAST_32_CHARS

# ── Feishu Integration ──────────────────────────────────────
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=YOUR_FEISHU_APP_SECRET

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0

# ── Ports (for Docker Compose) ───────────────────────────────
FRONTEND_PORT=3000
HTTP_PORT=80
HTTPS_PORT=443
